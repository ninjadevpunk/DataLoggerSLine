<Page x:Class="Data_Logger_1._3.Views.Account.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Data_Logger_1._3.Views.Account" xmlns:components="clr-namespace:Data_Logger_1._3.Components"
      mc:Ignorable="d"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      d:Background="White"
      Title="Settings">

    <Border Padding="40 60">
        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="650"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <!-- #region FEEDBACK FIELDS SIDE -->


            <Grid Margin="20 10 0 10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="45" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>


                <!-- HEADING -->
                <TextBlock Grid.Column="0" Grid.Row="0" Style="{DynamicResource HEADING5}"
                   Text="SETTINGS"/>






                <!--#region ACCOUNT FIELDS -->
                
                
                
                
                
                <StackPanel Grid.Row="3" VerticalAlignment="Stretch">
                    
                    <!-- ACCOUNT -->
                    <Border Padding="10 30">
                        <TextBlock Text="Account" Style="{DynamicResource text_minorHEADING1}" />
                    </Border>
                    
                    <!-- Profile Picture -->
                    <Border Padding="30 10">
                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>


                            <Border x:Name="image_PROFILE_PIC" Style="{DynamicResource image_displayPic}"
                                    >
                                <Path Style="{DynamicResource path_USER}"
                                      Visibility="{Binding DefaultPicVisibility, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                            
                            <!-- Browse Button -->
                            <Button Grid.Column="2"  x:Name="button_BROWSE_PICTURE" Style="{DynamicResource ACTIONBrowse}"
                                    Command="{Binding OpenImageCommand}">
                                <TextBlock Style="{DynamicResource text_button01}"
                                           Text="Browse"/>
                            </Button>


                            <TextBlock Grid.Column="4" Style="{DynamicResource text_LABEL02}"
                                       Text="{Binding DisplayPicPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       TextAlignment="Left"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>

                    <!-- FIRST AND LAST NAME -->
                    <Grid Margin="0 2.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- FIRST NAME -->
                        <components:PlainInputField x:Name="inputText_FIRSTNAME" Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                PlaceholderText="Name"
                                DynamicPlaceholderText="Name"
                                UserTextBoxStyle="{DynamicResource inputText_LOGIN}"
                                UserTextBlockStyle="{DynamicResource text_login_PLACEHOLDER}"
                                UserInput="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                />

                        <!-- LAST NAME -->
                        <components:PlainInputField x:Name="inputText_SURNAME" Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                PlaceholderText="Surname"
                                DynamicPlaceholderText="Surname"
                                UserTextBoxStyle="{DynamicResource inputText_LOGIN}"
                                UserTextBlockStyle="{DynamicResource text_login_PLACEHOLDER}"
                                UserInput="{Binding Surname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                />


                    </Grid>

                    <!-- EMAIL -->
                    <Grid Margin="0 2.5">
                        <components:PlainInputField x:Name="inputText_EMAIL"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    PlaceholderText="Email*"
                                                    DynamicPlaceholderText="Email*"
                                                    UserTextBoxStyle="{DynamicResource inputText_LOGIN}"
                                                    UserTextBlockStyle="{DynamicResource text_login_PLACEHOLDER}"
                                                    UserInput="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>


                    <!-- EMPLOYEE? -->
                    <Grid Margin="0 2.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Style="{DynamicResource text_LABEL01}"
                                   Text="Company Employee"
                                   TextAlignment="Left"
                                   Padding="10 0"/>

                        <Grid Grid.Column="1"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="10">
                            
                            
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>


                            <!-- YES -->
                            <TextBlock Grid.Column="0" Style="{DynamicResource text_LABEL02}"
                                       Text="Yes"
                                       Margin="5 0"/>
                            
                            <CheckBox Grid.Column="1" Style="{DynamicResource check_SIGNUP}" x:Name="checkBox_YES"
                                      IsChecked="{Binding IsCompanyEmployee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0 0 10 0"/>


                            <!-- NO -->
                            <TextBlock Grid.Column="2" Style="{DynamicResource text_LABEL02}"
                                       Text="No"
                                       Margin="5 0"/>
                            
                            <CheckBox Grid.Column="3" Style="{DynamicResource check_SIGNUP}" x:Name="checkBox_NO"
                                      Background="{DynamicResource iconCOLOURAccent01}"
                                      Foreground="{DynamicResource WHITE}"
                                      IsChecked="{Binding IsNotCompanyEmployee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            
                        </Grid>
                    </Grid>

                    <!-- NAME OF COMPANY -->
                    <Grid Margin="0 2.5">
                        <components:PlainInputField x:Name="inputText_COMPANY"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    PlaceholderText="Company Name*"
                                                    DynamicPlaceholderText="Company Name*"
                                                    IsEnabled="{Binding IsCompanyEmployee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    UserTextBoxStyle="{DynamicResource inputText_LOGIN}"
                                                    UserTextBlockStyle="{DynamicResource text_login_PLACEHOLDER}"
                                                    UserInput="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- COMPANY ADDRESS -->
                    <Grid Margin="0 2.5">
                        <components:PlainInputField x:Name="inputText_COMPANY_ADDRESS"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    PlaceholderText="Company Address"
                                                    DynamicPlaceholderText="Company Address"
                                                    IsEnabled="{Binding IsCompanyEmployee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    UserTextBoxStyle="{DynamicResource inputText_LOGIN}"
                                                    UserTextBlockStyle="{DynamicResource text_login_PLACEHOLDER}"
                                                    UserInput="{Binding CompanyAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                </StackPanel>
                





                <Border Grid.Row="4"
                        Padding="10"
                        HorizontalAlignment="Stretch">


                    <Button x:Name="button_PASSWORD_RESET_LINK" Style="{DynamicResource ACTION}"
                            HorizontalAlignment="Right"
                            Width="auto"
                            Command="{Binding PasswordResetCommand}">

                        <TextBlock Style="{DynamicResource text_button01}"
                                   Text="Request Password Reset"/>
                    </Button>
                </Border>


                <Border Grid.Row="5"
                        Padding="10"
                        HorizontalAlignment="Stretch">


                    <Button x:Name="button_DELETE_ACCOUNT" Style="{DynamicResource ACTION}"
                            HorizontalAlignment="Right"
                            Command="{Binding DeleteAccountCommand}">

                        <TextBlock Style="{DynamicResource text_button01}"
                                   Text="Delete Account"/>
                    </Button>
                </Border>
                <!--#endregion-->
                
                
                
                
                
                
                
                <!-- #region THEME FIELDS -->
                <StackPanel Grid.Row="6" VerticalAlignment="Stretch" >

                    <!-- THEME -->
                    <Border Padding="10 30">
                        <TextBlock Text="Theme" Style="{DynamicResource text_minorHEADING1}" />
                    </Border>
                    
                    
                    <!-- Theme Options -->
                    <components:ComboBoxInputField x:Name="theme_CHOICE"
                                                   UserTextBoxStyle="{DynamicResource inputText}"
                                                   Enabled="False"
                                                   UserComboInput="Grey"
                                                   IsEnabled="False"
                                                   />


                </StackPanel>

            </Grid>




            <!--#endregion-->



            <!-- #region SUBMIT -->

            






            <!--#endregion-->


        </Grid>
    </Border>
</Page>
