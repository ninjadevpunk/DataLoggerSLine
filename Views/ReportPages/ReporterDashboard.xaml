<Page x:Class="Data_Logger_1._3.Views.ReportPages.ReporterDashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:components="clr-namespace:Data_Logger_1._3.Components"
      mc:Ignorable="d" 
      MinHeight="899"
      d:Width="1100"
      Margin="59 0 0 0"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Top"
      d:Background="White"
      Title="Reporter">

    <Grid Margin="0 50">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>




        <components:SearchBarControl x:Name="inputText_SEARCH" Grid.Column="0"
                                     UserTextBoxStyle="{DynamicResource inputText}"
                                     UserTextBlockStyle="{DynamicResource text_Placeholder}"
                                     PlaceholderText="Search"
                                     DynamicPlaceholderText="Search"
                                     UserComboInput="{Binding Query, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     SearchResults="{Binding SearchBarItems, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     EnterInternalCommand="{Binding SearchCommand}"

            />

        <components:ComboBoxField x:Name="inputText_PROJECT" Grid.Column="0" Grid.Row="2"
                                       Enabled="True"
                                       UserTextBoxStyle="{DynamicResource inputText}"
                                       UserTextBlockStyle="{DynamicResource text_Placeholder}"
                                       UserSelection="{Binding Project, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                       Items="{Binding Projects, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                       ComboBoxSelectionChanged="on_Project_Changed"/>

        <components:ComboBoxField x:Name="inputText_APP" Grid.Column="0" Grid.Row="4"
                                       Enabled="{Binding ApplicationEnabled}"
                                       UserTextBoxStyle="{DynamicResource inputText}"
                                       UserTextBlockStyle="{DynamicResource text_Placeholder}"
                                       UserSelection="{Binding Application, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                       Items="{Binding Applications, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                       ToolTip="{Binding ApplicationToolTip}"
                                       ComboBoxSelectionChanged="on_Application_Changed"
                                       />










        <!-- LOGS -->
        <ListView x:Name="list_LOGS" Style="{DynamicResource listView_REPORT_list}" Grid.Column="0" Grid.Row="6"
              ItemContainerStyle="{DynamicResource listView_REPORT_list_ITEM}"
              ItemsSource="{Binding Logs, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />









        <!-- MAIN BUTTONS -->
        <Grid Grid.Column="2" Grid.Row="6"
            HorizontalAlignment="Left">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
            </Grid.RowDefinitions>
            
            <!-- CREATE REPORT BUTTON -->
            <Button x:Name="button_EXPORT" Grid.Row="1" Style="{DynamicResource PRIMARYReport}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Margin="10 0"
                    ToolTip="Export the project as a PDF"
                    Command="{Binding ExportCommand}">

                <TextBlock Style="{DynamicResource text_button01}"
                   Text="Export"
                   />
            </Button>


            <!-- RETURN TO DASHBOARD BUTTON -->
            <Button x:Name="button_RETURN" Grid.Row="3" Style="{DynamicResource ACTIONReturnToDashboard}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Command="{Binding ReturnToDashboard}" />

        </Grid>
    </Grid>
</Page>
