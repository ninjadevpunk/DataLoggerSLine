<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DISPLAY PIC -->
    <Style x:Key="image_displayPic" TargetType="Border">
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlaceholderText}"/>
        <Setter Property="BorderThickness" Value="0.6"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="Width" Value="50"/>
        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="{Binding SignUpImage}" Stretch="UniformToFill"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="image_wallpaper" TargetType="Border">
        <Setter Property="CornerRadius" Value="3 0 0 3"/>
        <Setter Property="Height" Value="899"/>
        <Setter Property="Width" Value="389"/>
    </Style>
    
</ResourceDictionary>