<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DISPLAY PIC -->
    <Style x:Key="image_displayPic" TargetType="Border">
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlaceholderText}"/>
        <Setter Property="BorderThickness" Value="0.6"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="Width" Value="50"/>
        <Setter Property="RenderOptions.BitmapScalingMode" Value="Linear"/>
        <Setter Property="RenderOptions.CachingHint" Value="Cache"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="{Binding SignUpImage}" Stretch="UniformToFill" />
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="image_wallpaper" TargetType="Border">
        <Setter Property="CornerRadius" Value="3 0 0 3"/>
        <Setter Property="Height" Value="899"/>
        <Setter Property="Width" Value="389"/>
    </Style>

    <Style x:Key="image_viewer_background" TargetType="Border">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Height" Value="899"/>
        <Setter Property="Width" Value="1145"/>
        <Setter Property="Padding" Value="40 60"/>
        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="/Assets/viewer_wallpaper.png" Stretch="UniformToFill"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="image_viewer_logo" TargetType="Border">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Height" Value="19.05"/>
        <Setter Property="Width" Value="20"/>
        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="/Assets/login_logo.png" Stretch="UniformToFill"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>