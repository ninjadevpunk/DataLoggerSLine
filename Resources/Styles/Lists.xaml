<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">



    <!-- LOG CACHE LIST VIEW -->
    <Style x:Key="listView_LOGCACHE" TargetType="{x:Type ListView}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource STROKE}"/>
        <Setter Property="BorderThickness" Value="0.6"/>
        <Setter Property="Height" Value="auto"/>
        <Setter Property="MinWidth" Value="650"/>
        <Setter Property="MaxWidth" Value="900"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource BLACK}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
        <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListView}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="1"
                            SnapsToDevicePixels="true"
                            CornerRadius="5">
                        <ScrollViewer Focusable="false" Padding="{TemplateBinding Padding}">
                            <!-- Grid makes the items in ListView behave. -->
                            <Grid>
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                            />
                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="{Binding NoLogsMessageVisibility}" >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="1" Text="No Logs Cached" Style="{DynamicResource text_button02}" 
                                               Foreground="{DynamicResource PlaceholderText}" />
                                    <TextBlock Grid.Row="2" Text="Click &quot;Create Log&quot; to create logs and they will appear here." Style="{DynamicResource text_button01}"
                                               Foreground="{DynamicResource PlaceholderText}" />

                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                    <ControlTemplate.Triggers>


                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsGrouping" Value="true"/>
                                <Condition Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="false"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                        </MultiTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="listView_LOGCACHE_ITEM" TargetType="{x:Type ListViewItem}" >
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Padding" Value="4,1"/>
        <Setter Property="Height" Value="170"/>
        <Setter Property="Margin" Value="0 5 5 0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{DynamicResource ListItem}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListViewItem}">
                    <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="0"
                        SnapsToDevicePixels="true"
                        CornerRadius="3"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}" >
                        <Border Padding="30 5 30 0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom" >

                            <StackPanel Orientation="Vertical" HorizontalAlignment="{TemplateBinding HorizontalAlignment}">

                                <!-- HEADING -->
                                <Grid Margin="0 5">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="0.7*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="text_PROJECTNAME" Style="{DynamicResource text_LIST_LABEL_HEADING}"
                                           Text="{Binding ProjectName}"/>

                                    <!-- ERSO -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            HorizontalAlignment="Right">

                                        <!-- ERROR -->
                                        <Ellipse x:Name="ellipse_LIST_ERROR" Style="{DynamicResource ellipse_LIST_ERSO}"
                                             Fill="{DynamicResource postIT_ERROR}"/>

                                        <TextBlock x:Name="text_LIST_ERROR" Style="{DynamicResource text_LIST_LABEL_ERSO}"
                                               Text="{Binding ErrorCount}"
                                               Margin="10 0" />


                                        <!-- SOLUTION -->
                                        <Ellipse x:Name="ellipse_LIST_SOLUTION" Style="{DynamicResource ellipse_LIST_ERSO}"
                                             Fill="{DynamicResource postIT_SOLUTION}"/>

                                        <TextBlock x:Name="text_LIST_SOLUTION" Style="{DynamicResource text_LIST_LABEL_ERSO}"
                                               Text="{Binding SolutionCount}"
                                               Margin="10 0" />


                                        <!-- SUGGESTION -->
                                        <Ellipse x:Name="ellipse_LIST_SUGGESTION" Style="{DynamicResource ellipse_LIST_ERSO}"
                                             Fill="{DynamicResource postIT_SUGGESTION}" />

                                        <TextBlock x:Name="text_LIST_SUGGESTION" Style="{DynamicResource text_LIST_LABEL_ERSO}"
                                               Text="{Binding SuggestionCount}"
                                               Margin="10 0"/>


                                        <!-- COMMENT -->
                                        <Ellipse x:Name="ellipse_LIST_COMMENT" Style="{DynamicResource ellipse_LIST_ERSO}"
                                             Fill="{DynamicResource postIT_COMMENT}"/>

                                        <TextBlock x:Name="text_LIST_COMMENT" Style="{DynamicResource text_LIST_LABEL_ERSO}"
                                               Text="{Binding CommentCount}"
                                               Margin="10 0"/>



                                    </StackPanel>

                                </Grid>

                                <TextBlock x:Name="text_LIST_DATE" Style="{DynamicResource text_LIST_LABEL_DATE}"
                                       Text="{Binding StartEndDate}"
                                       Margin="0 5"
                                       />

                                <TextBlock x:Name="text_LIST_CONTENT" Style="{DynamicResource text_LIST_LABEL_CONTENT}"
                                       Text="{Binding NotaryContent}"
                                       Margin="0 5"/>

                                <!-- Maximum value is 20 minutes in Milliseconds xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx -->
                                <ProgressBar x:Name="progress_CACHE_ITEM"
                                             Height="8"
                                             Minimum="0"
                                             Maximum="1200" 
                                             Value="{Binding TimeRemaining, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource PANEL}" />


                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Context Menu -->
                    <ControlTemplate.Resources>
                        <ContextMenu x:Key="ItemContextMenu">
                            <MenuItem Header="Edit" Command="{Binding EditCommand}"
                                      CommandParameter="{Binding}" />
                            <MenuItem Header="View" Command="{Binding ViewCommand}"
                                      CommandParameter="{Binding}" />
                            <MenuItem Header="Delete" Command="{Binding QuickDeleteCacheItemCommand}"
                                      CommandParameter="{Binding}"/>
                        </ContextMenu>
                    </ControlTemplate.Resources>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
                            <Setter Property="Foreground" TargetName="progress_CACHE_ITEM" Value="{DynamicResource HOVERPrimaryColour}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                <Condition Property="IsSelected" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
                            <Setter Property="Foreground" TargetName="progress_CACHE_ITEM" Value="{DynamicResource HOVERPrimaryColour}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Selector.IsSelectionActive" Value="True"/>
                                <Condition Property="IsSelected" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
                            <Setter Property="Foreground" TargetName="progress_CACHE_ITEM" Value="{DynamicResource HOVERPrimaryColour}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="TextElement.Foreground" TargetName="Bd" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- REPORT LIST VIEW -->
    <Style x:Key="listView_REPORT_list" TargetType="{x:Type ListView}" BasedOn="{StaticResource listView_LOGCACHE}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListView}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="4 0"
                            SnapsToDevicePixels="true"
                            CornerRadius="5" >
                        <ScrollViewer Focusable="false" Padding="{TemplateBinding Padding}">
                            <!-- Grid makes the items in ListView behave. -->
                            <Grid>
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                        />

                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="{Binding NoLogsMessageVisibility, UpdateSourceTrigger=PropertyChanged, 
                                    Mode=TwoWay}" >
                                    
                                    
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="1" Text="No Logs to Show" Style="{DynamicResource text_button02}" 
                                               Foreground="{DynamicResource PlaceholderText}" />
                                    <TextBlock Grid.Row="2" Text="Create logs in the log cache page and they will show up here once stored."
                                               Style="{DynamicResource text_button01}"
                                               Foreground="{DynamicResource PlaceholderText}" />

                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="false"/>


                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsGrouping" Value="true"/>
                                <Condition Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="false"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="listView_REPORT_list_ITEM" TargetType="{x:Type ListViewItem}"  BasedOn="{StaticResource listView_LOGCACHE_ITEM}">
        <Setter Property="Height" Value="220"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListViewItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="0"
                            SnapsToDevicePixels="true"
                            CornerRadius="3"
                            HorizontalAlignment="{TemplateBinding HorizontalAlignment}" >
                        <Border Padding="30 5 30 0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom" >

                            <StackPanel Orientation="Vertical" HorizontalAlignment="{TemplateBinding HorizontalAlignment}">

                                <!-- HEADING -->
                                <Grid Margin="0 5">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="0.7*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="text_PROJECTNAME" Style="{DynamicResource text_LIST_LABEL_HEADING}"
                                       Text="{Binding ProjectName}"/>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                HorizontalAlignment="Right">

                                        <!-- ERROR -->
                                        <Ellipse x:Name="ellipse_LIST_ERROR" Style="{DynamicResource ellipse_LIST_ERSO}"
                                         Fill="{DynamicResource postIT_ERROR}"/>

                                        <TextBlock x:Name="text_LIST_ERROR" Style="{DynamicResource text_LIST_LABEL_ERSO}"
                                           Text="{Binding ErrorCount}" Margin="10 0"/>


                                        <!-- SOLUTION -->
                                        <Ellipse x:Name="ellipse_LIST_SOLUTION" Style="{DynamicResource ellipse_LIST_ERSO}"
                                         Fill="{DynamicResource postIT_SOLUTION}"/>

                                        <TextBlock x:Name="text_LIST_SOLUTION" Style="{DynamicResource text_LIST_LABEL_ERSO}"
                                           Text="{Binding SolutionCount}" Margin="10 0"/>


                                        <!-- SUGGESTION -->
                                        <Ellipse x:Name="ellipse_LIST_SUGGESTION" Style="{DynamicResource ellipse_LIST_ERSO}"
                                         Fill="{DynamicResource postIT_SUGGESTION}"/>

                                        <TextBlock x:Name="text_LIST_SUGGESTION" Style="{DynamicResource text_LIST_LABEL_ERSO}"
                                           Text="{Binding SuggestionCount}" Margin="10 0"/>


                                        <!-- COMMENT -->
                                        <Ellipse x:Name="ellipse_LIST_COMMENT" Style="{DynamicResource ellipse_LIST_ERSO}"
                                         Fill="{DynamicResource postIT_COMMENT}"/>

                                        <TextBlock x:Name="text_LIST_COMMENT" Style="{DynamicResource text_LIST_LABEL_ERSO}"
                                           Text="{Binding CommentCount}" Margin="10 0"/>



                                    </StackPanel>

                                </Grid>

                                <TextBlock x:Name="text_LIST_DATE" Style="{DynamicResource text_LIST_LABEL_DATE}"
                                   Text="{Binding StartEndDate}" Margin="0 5"
                                   />

                                <TextBlock x:Name="text_LIST_CONTENT" Style="{DynamicResource text_LIST_LABEL_CONTENT}"
                                   Text="{Binding NotaryContent}" Margin="0 5"/>

                                <Border x:Name="tools" Visibility="Hidden">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
                                        <Button Style="{DynamicResource toolbutton_Adobe_EXPORT}"
                                                Margin="10"
                                                Command="{Binding SingleExport}"
                                                CommandParameter="{Binding}" />
                                        <Button Style="{DynamicResource toolbutton_PRINTER_EXPORT}" Visibility="Collapsed"
                                                Margin="10"
                                                Command="{Binding}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Border>


                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Context Menu -->
                    <ControlTemplate.Resources>
                        <ContextMenu x:Key="ItemContextMenu">
                            <MenuItem Header="Edit" Command="{Binding Edit}"
                                      CommandParameter="{Binding}" />
                            <MenuItem Header="View" Command="{Binding View}"
                                      CommandParameter="{Binding}" />
                            <MenuItem Header="Delete" Command="{Binding Delete}"
                                      CommandParameter="{Binding}" />
                        </ContextMenu>
                    </ControlTemplate.Resources>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
                            <Setter Property="Visibility" TargetName="tools" Value="Visible"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                <Condition Property="IsSelected" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Selector.IsSelectionActive" Value="True"/>
                                <Condition Property="IsSelected" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="TextElement.Foreground" TargetName="Bd" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- #region NOTES LIST VIEW -->



    <Style x:Key="listView_NOTES_list" TargetType="{x:Type ListView}" BasedOn="{StaticResource listView_LOGCACHE}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListView}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="1"
                            SnapsToDevicePixels="true"
                            CornerRadius="3">

                        <ScrollViewer Focusable="false" Padding="{TemplateBinding Padding}">
                            <!-- Grid makes the items in ListView behave. -->
                            <Grid>
                                <WrapPanel Orientation="Horizontal" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" IsItemsHost="True"
                                    />

                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="{Binding NoLogsMessageVisibility, UpdateSourceTrigger=PropertyChanged, 
                                    Mode=TwoWay}" >
                                    
                                    
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="1" Text="No Notes" Style="{DynamicResource text_button02}"
                                               Foreground="{DynamicResource PlaceholderText}" />
                                    <TextBlock Grid.Row="2" Text="Click &quot;New Note&quot; to create notes and they will appear here." Style="{DynamicResource text_button01}"
                                               Foreground="{DynamicResource PlaceholderText}" />

                                </Grid>

                            </Grid>
                        </ScrollViewer>
                    </Border>
                    <ControlTemplate.Triggers>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsGrouping" Value="true"/>
                                <Condition Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="false"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="template_NOTE_checklist_ITEM_inner_checklist" TargetType="{x:Type ListViewItem}" >
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListViewItem}">

                    <Border Padding="10 0 10 0" >

                        <Grid>

                            <Ellipse Fill="{DynamicResource BLACK}"
                                Height="8" Width="8" />
                            <TextBlock Text="{Binding CheckListItem}"
                                       Height="32"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       FontFamily="{DynamicResource Red Hat Display}"
                                       FontWeight="Regular"
                                       FontSize="13" />

                        </Grid>

                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <!-- CHECKLIST NOTE TEMPLATE -->
    
    
    
    <ControlTemplate x:Key="template_NOTE_checklist_ITEM" TargetType="{x:Type ListViewItem}">
        <Border x:Name="Bd"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            Padding="10"
            SnapsToDevicePixels="true"
            CornerRadius="3"
            HorizontalAlignment="{TemplateBinding HorizontalAlignment}">

            <Grid>
                <Grid.Resources>
                    <Style x:Key="border_NOTES" TargetType="Border">
                        <Setter Property="Padding" Value="10"/>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>

                <!-- NOTE SUBJECT -->
                <Border Style="{StaticResource border_NOTES}"
                        Padding="10 0">

                    <Grid Height="40">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="35"/>
                        </Grid.ColumnDefinitions>

                        <!-- SUBJECT HERE -->
                        <TextBlock x:Name="note_SUBJECT" Style="{DynamicResource text_NOTE_HEADING}"
                                   Margin="0 0 10 0"
                                   Text="{Binding Subject}"/>

                        <Button Grid.Column="1" x:Name="button_DELETE_NOTE" Style="{DynamicResource toolbutton_DELETE}"
                                Command="{Binding DeleteNoteItemCommand}"/>
                    </Grid>

                </Border>

                <!-- NOTE CONTENT SNIPPET -->
                <Border Grid.Row="2" Style="{StaticResource border_NOTES}">
                    <Grid>
                        <ListView x:Name="note_CHECKLIST" ItemContainerStyle="{StaticResource template_NOTE_checklist_ITEM_inner_checklist}"
                                  ItemsSource="{Binding CheckListItems}"/>

                    </Grid>
                </Border>

                <!-- NOTE DATE -->
                <Border Grid.Row="4" Style="{StaticResource border_NOTES}">
                    <TextBlock x:Name="note_DATE" Style="{DynamicResource text_NOTE_DATE02}"
                           Text="{Binding Date}"/>
                </Border>
            </Grid>

        </Border>
        <ControlTemplate.Triggers>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                    <Condition Property="IsSelected" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="Selector.IsSelectionActive" Value="True"/>
                    <Condition Property="IsSelected" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Background" TargetName="Bd" Value="{DynamicResource SELECTEDListItem}"/>
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="TextElement.Foreground" TargetName="Bd" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

