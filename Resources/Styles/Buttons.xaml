                            <Setter Property="Background" TargetName="border" Value="{DynamicResource WhiteAccent02}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


