<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- NORMAL COLOURS -->
    <SolidColorBrush x:Key="BLACK">#000000</SolidColorBrush>
    <SolidColorBrush x:Key="WHITE">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="GREEN">#009900</SolidColorBrush>
    <SolidColorBrush x:Key="YELLOW">#FFF500</SolidColorBrush>
    <SolidColorBrush x:Key="RED">#FF0000</SolidColorBrush>
    <SolidColorBrush x:Key="SILVER">#C0C0C0</SolidColorBrush>
    
    
    <!-- BRAND COLOURS -->
    <SolidColorBrush x:Key="PrimaryColour">#009900</SolidColorBrush>
    <SolidColorBrush x:Key="HOVERPrimaryColour">#00B200</SolidColorBrush>
    <SolidColorBrush x:Key="SecondaryColour">#00A4FF</SolidColorBrush>
    
        <!-- White Accent 01 -->
        <SolidColorBrush x:Key="AccentColour">#EAF1E7</SolidColorBrush>
        <SolidColorBrush x:Key="HOVERAccentColour">#EAF1E7</SolidColorBrush>

        <!-- ERSO -->
        <SolidColorBrush x:Key="postIT_ERROR">#FF0000</SolidColorBrush>
