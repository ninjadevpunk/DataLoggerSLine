    <SolidColorBrush x:Key="subMenuItem">#EAF1E7</SolidColorBrush>
    <SolidColorBrush x:Key="HOVERSubMenuItem">#656565</SolidColorBrush>

    <!-- List -->
    <SolidColorBrush x:Key="SELECTEDListItem">#C5CCC4</SolidColorBrush>
