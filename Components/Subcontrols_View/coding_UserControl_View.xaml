<UserControl x:Class="Data_Logger_1._3.Components.Subcontrols_View.coding_UserControl_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Data_Logger_1._3.Components.Subcontrols_View" xmlns:components="clr-namespace:Data_Logger_1._3.Components"
             mc:Ignorable="d"
             d:Background="White"
             HorizontalAlignment="Stretch"
             x:Name="control_CODING_fields_View" >

    <StackPanel>

        <!-- BUGS -->        
        <Border 
                HorizontalAlignment="Stretch"
            Padding="20 0"
            Height="35" >

            <TextBlock x:Name="text_BUGS" Style="{DynamicResource text_LABEL03}"
                       Text="{Binding BugsFound}" />

        </Border>

        <!-- LAUNCH SUCCESFUL -->
        <Border
            Padding="20 0"
            Height="35" >

            <TextBlock x:Name="text_LAUNCHSUCCESFUL" Style="{DynamicResource text_LABEL03}"
                       Text="{Binding ApplicationOpened}" />

        </Border>


    </StackPanel>

</UserControl>
