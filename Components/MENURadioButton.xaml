<UserControl x:Class="Data_Logger_1._3.Components.MENURadioButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Data_Logger_1._3.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="control_MENU_item"
             >
    
    <UserControl.Resources>
        <Style x:Key="MENU_FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="2" StrokeDashArray="1 2" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="true" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OptionMarkFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="14,0,0,0" StrokeDashArray="1 2" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="true" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="RadioButton.Disabled.Background" Color="#FFE6E6E6"/>
        <SolidColorBrush x:Key="RadioButton.Disabled.Border" Color="#FFBCBCBC"/>
        <SolidColorBrush x:Key="RadioButton.Disabled.Glyph" Color="#FF707070"/>
        <Style x:Key="radio_MENU_ITEM" TargetType="{x:Type RadioButton}">
            <Setter Property="FocusVisualStyle" Value="{StaticResource MENU_FocusVisual}"/>
            <Setter Property="Background" Value="{DynamicResource PANELWHITE}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="radioButtonBorder" Background="{TemplateBinding Background}"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         Height="{TemplateBinding Height}"
                         >
                            <Grid Height="60" Margin="50 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Path x:Name="path_icon"  Grid.Column="0" Style="{Binding MENUIcon, ElementName=control_MENU_item}"
                                    Fill="{DynamicResource BLACK}"
                                    />

                                <TextBlock x:Name="text_ITEM_name"  Grid.Column="2" Style="{DynamicResource text_MENU}"
                                    Text="{Binding Category, ElementName=control_MENU_item}"
                                    />
                            </Grid>
                        </Border>


                        <ControlTemplate.Triggers>
                            <Trigger Property="HasContent" Value="true">
                                <Setter Property="FocusVisualStyle" Value="{StaticResource OptionMarkFocusVisual}"/>
                                <Setter Property="Padding" Value="4,-1,0,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="radioButtonBorder" Value="{DynamicResource SELECTEDMainMenuItem}"/>
                                <Setter Property="Fill" TargetName="path_icon" Value="{DynamicResource WHITE}"/>
                                <Setter Property="Foreground" TargetName="text_ITEM_name" Value="{DynamicResource WHITE}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Opacity" TargetName="radioButtonBorder" Value=".3"/>
                                <Setter Property="Opacity" TargetName="path_icon" Value=".3"/>
                                <Setter Property="Opacity" TargetName="text_ITEM_name" Value=".3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="radioButtonBorder" Value="{DynamicResource HOVERMainMenuItem}"/>
                                <Setter Property="Fill" TargetName="path_icon" Value="{DynamicResource WHITE}"/>
                                <Setter Property="Foreground" TargetName="text_ITEM_name" Value="{DynamicResource WHITE}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter Property="Background" TargetName="radioButtonBorder" Value="{DynamicResource SELECTEDMainMenuItem}"/>
                                <Setter Property="Fill" TargetName="path_icon" Value="{DynamicResource WHITE}"/>
                                <Setter Property="Foreground" TargetName="text_ITEM_name" Value="{DynamicResource WHITE}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <RadioButton x:Name="radio_MENU_item" Style="{DynamicResource radio_MENU_ITEM}"
                 IsChecked="{Binding Checked, ElementName=control_MENU_item}"
                 GroupName="{Binding Crew, ElementName=control_MENU_item}"
                 Checked="on_item_CHECKED"
                 Unchecked="on_item_UNCHECKED"
                 />


</UserControl>
