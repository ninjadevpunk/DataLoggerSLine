<UserControl x:Class="Data_Logger_1._3.Components.PasswordInputField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="control_INPUT_password"
             >
    <Border>
        <Grid>
            <TextBlock x:Name="text_Placeholder_text" Style="{DynamicResource text_login_PLACEHOLDER}"
                       Text="Password"
                       TextAlignment="{Binding Aligned, ElementName=control_INPUT_password}"
                       />
            <PasswordBox x:Name="control_inputText_Password" Style="{DynamicResource inputText_LOGIN_password}"
                         PasswordChanged="on_Password_changed"
                         LostFocus="on_Password_lostFocus"
                         />
        </Grid>
    </Border>
</UserControl>
