<UserControl x:Class="Data_Logger_1._3.Components.PlainInputField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Data_Logger_1._3.Components"
             mc:Ignorable="d" 
             d:DesignHeight="34" d:DesignWidth="430"
             >
    <Border CornerRadius="2"
            Background="{DynamicResource WHITE}"
            Height="35"
            >
        <Grid>
            <!-- Placeholder Text here-->
            <TextBlock x:Name="text_PlaceholderText" Style="{DynamicResource text_login_PLACEHOLDER}"
                       Text="Placeholder text"
                       />
            
            <!-- User Input here -->
            <TextBox x:Name="inputText_text" Style="{DynamicResource inputText_login}"
                     
                     />
        </Grid>
    </Border>
</UserControl>
